   body {
        background-color: #0a0a0a;
        background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.05) 1px, transparent 0);
        background-size: 20px 20px;
        overflow-x: hidden;
      }
      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #1a1a1a;
      }
      ::-webkit-scrollbar-thumb {
        background-color: #444;
        border-radius: 4px;
        border: 2px solid #1a1a1a;
      }
      ::-webkit-scrollbar-thumb:hover {
        background-color: #FF0000;
      }

      /* Animated Border */
      @keyframes animated-border-glow {
        0% {
          border-color: #ff0000;
          box-shadow: 0 0 4px rgba(255, 0, 0, 0.4);
        }
        50% {
          border-color: #d63333;
          box-shadow: 0 0 12px rgba(255, 0, 0, 0.7);
        }
        100% {
          border-color: #ff0000;
          box-shadow: 0 0 4px rgba(255, 0, 0, 0.4);
        }
      }
      
      /* Message Fade-in Animation */
      @keyframes fadeIn {
        from { 
          opacity: 0; 
          transform: translateY(10px); 
        }
        to { 
          opacity: 1; 
          transform: translateY(0); 
        }
      }
      .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
      }

      /* Markdown Content Styles */
      .markdown-content h1, .markdown-content h2, .markdown-content h3, .markdown-content h4 {
          color: #f3f4f6; /* Lighter color for headings */
          margin-bottom: 0.5em;
          margin-top: 1em;
          font-weight: 600;
          border-bottom: 1px solid #4b5563; /* Subtle underline */
          padding-bottom: 0.3em;
      }
      .markdown-content h1 { font-size: 1.5em; }
      .markdown-content h2 { font-size: 1.25em; }
      .markdown-content h3 { font-size: 1.1em; }

      .markdown-content strong {
          color: #ffffff;
          font-weight: 600;
      }
      .markdown-content p {
          margin-bottom: 1em;
          line-height: 1.7; /* improve readability */
      }
      .markdown-content p:last-child {
          margin-bottom: 0;
      }
      .markdown-content a {
          color: #ff4d4d;
          text-decoration: underline;
          font-weight: 500;
      }
      .markdown-content a:hover {
          color: #ff8080;
      }
      .markdown-content ul {
          list-style-type: disc;
          list-style-position: inside;
          padding-left: 1em;
          margin-top: 0.5em;
          margin-bottom: 0.75em;
      }
      .markdown-content ol {
          list-style-type: decimal;
          list-style-position: inside;
          padding-left: 1em;
          margin-top: 0.5em;
          margin-bottom: 0.75em;
      }
      .markdown-content li {
          margin-bottom: 0.3em;
      }
      .markdown-content li::marker {
          color: #9ca3af;
      }

      /* Full Screen Message Viewer Styles */
      .fullscreen-markdown-wrapper .markdown-content {
        font-size: 1.05rem; /* Slightly larger text */
      }
      .fullscreen-markdown-wrapper .markdown-content p,
      .fullscreen-markdown-wrapper .markdown-content ul,
      .fullscreen-markdown-wrapper .markdown-content ol,
      .fullscreen-markdown-wrapper .markdown-content blockquote {
          margin-bottom: 1.25em; /* More vertical space */
          line-height: 1.7;
          padding-left: 1rem;
          padding-right: 1rem;
      }
      .fullscreen-markdown-wrapper .markdown-content h1, 
      .fullscreen-markdown-wrapper .markdown-content h2, 
      .fullscreen-markdown-wrapper .markdown-content h3 {
          font-weight: 700; /* Bolder headings */
          color: #ffffff;
          padding-left: 1rem;
          padding-right: 1rem;
      }
      .fullscreen-markdown-wrapper .markdown-content blockquote {
          border-left: 4px solid #550000;
          padding-left: 1em;
          color: #d1d5db;
      }
      .fullscreen-markdown-wrapper .markdown-content a {
          /* Handled by LinkBubble, no default styling needed here */
          text-decoration: none;
      }
  </style>
